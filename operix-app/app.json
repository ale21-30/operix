{
  "expo": {
    "name": "Operix",
    "slug": "operix-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icono.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icono.png",
      "resizeMode": "contain",
      "backgroundColor": "#04342C"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icono.png",
        "backgroundColor": "#04342C"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/icono.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "050f6c15-3c9f-416b-be76-66e9beee0ede"
      }
    },
    "owner": "ale_2130"
  }
}
